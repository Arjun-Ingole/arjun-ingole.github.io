---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '@fontsource/redaction-35/400-italic.css';
import '../styles/global.css';

const metadata = Astro.props.frontmatter ?? Astro.props;
const { title, description, date, category = 'Writing', readTime } = metadata;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} · Arjun Ingole</title>
	</head>
	<body>
		<div class="page-shell">
			<nav class="top-nav">
				<a href="/">Home</a>
				<a href="/blog">Blog</a>
				<span></span>
				<a class="contact" href="/#contact">Contact me</a>
			</nav>

			<main>
				<a class="back" href="/blog">← All writings</a>
				<article>
					<header class="article-header">
						<p class="eyebrow">{category}{readTime && ` · ${readTime}`}</p>
						<h1>{title}</h1>
						{description && <p class="dek">{description}</p>}
						<time>{date}</time>
					</header>
					<div class="prose"><slot /></div>
				</article>
			</main>
		</div>
	</body>
</html>

<style>
	:global(body) { min-height: 100vh; margin: 0; background-color: #09090b; background-image: repeating-linear-gradient(45deg, rgba(244,244,245,.03) 0 1px, transparent 1px 14px); color: #d4d4d8; }
	.page-shell { display: flow-root; min-height: 100vh; max-width: calc(50vw + 576px); margin-inline: auto; border-inline: 1px solid rgba(39,39,42,.8); background: #09090b; }
	.top-nav { position: sticky; top: 1rem; z-index: 30; display: flex; align-items: center; gap: .375rem; width: fit-content; margin: 1rem auto 0; padding: .72rem 1.4rem; border: 1px solid rgba(255,255,255,.15); border-radius: 1.25rem; background: rgba(39,39,42,.72); backdrop-filter: blur(24px); box-shadow: 0 12px 40px -10px rgba(0,0,0,.55), inset 0 1px rgba(255,255,255,.22); font-size: .9rem; }
	.top-nav a { padding: .375rem .75rem; border-radius: .5rem; color: #e4e4e7; text-decoration: none; }
	.top-nav a:hover { color: #fff; }
	.top-nav span { width: 1px; height: .875rem; margin-inline: .25rem; background: rgba(255,255,255,.15); }
	.top-nav .contact { background: rgba(255,255,255,.1); color: #fff; }
	main { max-width: 46rem; margin: 0 auto; padding: 5rem 1.5rem 8rem; }
	.back { display: inline-block; margin-bottom: 3.5rem; color: #71717a; font-size: .8rem; text-decoration: none; }
	.back:hover { color: #d4d4d8; }
	.article-header { padding-bottom: 2.5rem; border-bottom: 1px solid #27272a; }
	.eyebrow { margin: 0 0 1rem; color: #a1a1aa; font-family: 'Geist Mono Variable', monospace; font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; }
	h1 { max-width: 42rem; margin: 0; color: #fafafa; font-family: 'Redaction 35', serif; font-size: clamp(2.175rem, 7vw, 3.875rem); font-style: italic; font-weight: 400; line-height: .98; letter-spacing: -.025em; }
	.dek { max-width: 36rem; margin: 1.25rem 0; color: #a1a1aa; font-size: 1.05rem; line-height: 1.6; }
	time { color: #71717a; font-size: .75rem; }
	.prose { padding-top: 2.75rem; font-size: 1rem; line-height: 1.8; }
	.prose :global(p) { margin: 0 0 1.5rem; }
	.prose :global(p:first-child) { color: #e4e4e7; font-size: 1.15rem; line-height: 1.7; }
	.prose :global(h2) { margin: 3rem 0 1rem; color: #f4f4f5; font-size: 1.55rem; font-weight: 500; letter-spacing: -.02em; }
	.prose :global(h3) { margin: 3rem 0 1rem; color: #f4f4f5; font-size: 1.4rem; font-weight: 500; line-height: 1.3; letter-spacing: -.02em; }
	.prose :global(h4) { margin: 2.25rem 0 .75rem; color: #e4e4e7; font-size: 1.1rem; font-weight: 500; }
	.prose :global(ul), .prose :global(ol) { margin: 0 0 1.75rem; padding-left: 1.25rem; }
	.prose :global(ul) { list-style: disc; }
	.prose :global(ol) { list-style: decimal; }
	.prose :global(li) { margin: .5rem 0; padding-left: .35rem; }
	.prose :global(blockquote) { margin: 2.5rem 0; padding: .25rem 0 .25rem 1.5rem; border-left: 2px solid #fbbf24; color: #e4e4e7; font-family: 'Redaction 35', serif; font-size: 1.55rem; font-style: italic; line-height: 1.45; }
	.prose :global(blockquote p) { margin: 0; }
	.prose :global(a) { color: #e4e4e7; text-decoration: underline; text-decoration-color: #52525b; text-underline-offset: 3px; }
	.prose :global(strong) { color: #e4e4e7; font-weight: 600; }
	.prose :global(:not(pre) > code) { padding: .15rem .35rem; border: 1px solid #3f3f46; border-radius: .3rem; background: #18181b; color: #e4e4e7; font-family: 'Geist Mono Variable', monospace; font-size: .85em; }
	.prose :global(.astro-code) { overflow-x: auto; margin: 2rem 0; padding: 1.25rem; border: 1px solid #27272a; border-radius: .8rem; font-family: 'Geist Mono Variable', monospace; font-size: .82rem; line-height: 1.65; }
	.prose :global(table) { width: 100%; margin: 2rem 0; border-collapse: collapse; table-layout: fixed; font-size: .75rem; line-height: 1.45; }
	.prose :global(thead) { color: #f4f4f5; background: rgba(255,255,255,.035); }
	.prose :global(th), .prose :global(td) { padding: .55rem .65rem; border: 1px solid #3f3f46; text-align: left; vertical-align: top; overflow-wrap: anywhere; }
	.prose :global(th:first-child), .prose :global(td:first-child) { width: 28%; }
	.prose :global(th) { font-weight: 500; }
	.prose :global(hr) { margin: 3.5rem 0; border: 0; border-top: 1px solid #27272a; }
	@media (max-width: 520px) { .top-nav { padding-inline: .7rem; } .top-nav a { padding-inline: .55rem; } main { padding-top: 3.5rem; } }
</style>
